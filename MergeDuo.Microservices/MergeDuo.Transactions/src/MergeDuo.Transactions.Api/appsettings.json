{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cosmos": {
    "Endpoint": "https://your-cosmos-account.documents.azure.com:443/",
    "ConnectionString": "",
    "Database": "mergeduo",
    "TransactionsContainer": "transactions",
    "CardsContainer": "cards",
    "FixedRulesContainer": "fixedRules",
    "PartnershipsContainer": "partnerships",
    "AutoCreateContainers": false
  },
  "Jwt": {
    "Issuer": "https://your-frontend.example.com",
    "Audience": "mergeduo-api",
    "JwksUrl": "https://your-frontend.example.com/.well-known/jwks.json",
    "KeyId": "jwt-signing-rsa-v1",
    "PublicKeyPem": "",
    "PrivateKeyPem": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-frontend.example.com"
    ]
  },
  "Transactions": {
    "DefaultPageSize": 50,
    "MaxPageSize": 100,
    "MaxInstallments": 48,
    "DependencyTimeoutSeconds": 5,
    "ContinuationTokenSecret": ""
  },
  "InternalApi": {
    "SchedulerKey": ""
  },
  "RateLimit": {
    "GlobalPermitLimit": 300,
    "ListPermitLimit": 120,
    "GetPermitLimit": 180,
    "CreatePermitLimit": 30,
    "PatchPermitLimit": 60,
    "DeletePermitLimit": 30,
    "GroupReadPermitLimit": 60,
    "GroupDeletePermitLimit": 20,
    "CardUsagePermitLimit": 120
  },
  "AllowedHosts": "*"
}
