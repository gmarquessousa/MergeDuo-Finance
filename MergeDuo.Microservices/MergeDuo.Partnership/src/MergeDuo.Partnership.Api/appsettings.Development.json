{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cosmos": {
    "Endpoint": "https://your-cosmos-account.documents.azure.com:443/",
    "ConnectionString": "",
    "Database": "mergeduo",
    "UsersContainer": "users",
    "InvitesContainer": "mergeInvites",
    "PartnershipsContainer": "partnerships"
  },
  "Jwt": {
    "Issuer": "http://localhost:8080",
    "Audience": "mergeduo-api",
    "JwksUrl": "http://identity:8080/.well-known/jwks.json",
    "KeyId": "jwt-signing-rsa-v1"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  },
  "PublicApp": {
    "InviteBaseUrl": "http://localhost:8080/invites"
  },
  "Invite": {
    "ExpiresAfterHours": 72,
    "TokenEntropyBytes": 32
  },
  "RateLimit": {
    "GlobalPermitLimit": 300,
    "InviteCreatePermitLimit": 20,
    "InvitePreviewPermitLimit": 120,
    "InviteAcceptPermitLimit": 30,
    "PartnershipPermitLimit": 120
  },
  "AllowedHosts": "*"
}
