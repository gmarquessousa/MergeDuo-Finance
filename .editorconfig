root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.{cs,csproj,sln,json,md,yml,yaml,tf,ts,tsx,js,css,html}]
indent_size = 2

[*.cs]
indent_size = 4

[*.sln]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
