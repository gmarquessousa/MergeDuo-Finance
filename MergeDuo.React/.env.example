# MergeDuo React frontend - public build configuration.
#
# Production runs behind the ACA Web same-origin proxy. Keep
# VITE_USE_CROSS_ORIGIN_APIS=false unless you intentionally want the browser
# to call each API Container App directly.

VITE_USE_CROSS_ORIGIN_APIS=false

# Same-origin API bases used by the ACA Web proxy.
VITE_IDENTITY_API_BASE_URL=/
VITE_PROFILE_API_BASE_URL=/api/profile
VITE_PARTNERSHIP_API_BASE_URL=/api/partnership
VITE_CARDS_API_BASE_URL=/api
VITE_FIXED_RULES_API_BASE_URL=/api
VITE_TRANSACTIONS_API_BASE_URL=/api
VITE_AGGREGATES_API_BASE_URL=/api

# Google OAuth client id used by the Google Identity Services button.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional: app version surfaced to Identity for device fingerprinting.
# VITE_APP_VERSION=0.1.0
