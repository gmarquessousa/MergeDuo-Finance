<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Identity auth proxy" stopProcessing="true">
          <match url="^auth/(.*)$" />
          <action type="Rewrite" url="https://identity.example.com/auth/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="Identity users proxy" stopProcessing="true">
          <match url="^users/(.*)$" />
          <action type="Rewrite" url="https://identity.example.com/users/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="Identity discovery proxy" stopProcessing="true">
          <match url="^\.well-known/(.*)$" />
          <action type="Rewrite" url="https://identity.example.com/.well-known/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="Profile API proxy" stopProcessing="true">
          <match url="^api/profile/(.*)$" />
          <action type="Rewrite" url="https://profile.example.com/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="Partnership API proxy" stopProcessing="true">
          <match url="^api/partnership/(.*)$" />
          <action type="Rewrite" url="https://partnership.example.com/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="Cards API proxy" stopProcessing="true">
          <match url="^api/cards/?(.*)$" />
          <action type="Rewrite" url="https://cards.example.com/cards/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="FixedRules API proxy" stopProcessing="true">
          <match url="^api/fixed-rules/?(.*)$" />
          <action type="Rewrite" url="https://fixedrules.example.com/fixed-rules/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="Transactions API proxy" stopProcessing="true">
          <match url="^api/transactions/?(.*)$" />
          <action type="Rewrite" url="https://transactions.example.com/transactions/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="Aggregates API proxy" stopProcessing="true">
          <match url="^api/aggregates/?(.*)$" />
          <action type="Rewrite" url="https://aggregates.example.com/aggregates/{R:1}" appendQueryString="true" />
        </rule>
        <rule name="SPA fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
